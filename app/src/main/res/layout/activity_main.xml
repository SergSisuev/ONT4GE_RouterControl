<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- === Панель настроек (сворачивается при работе WebView) === -->
    <LinearLayout
        android:id="@+id/settings_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#F8F9FA"
        android:elevation="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ограничение работы Wi-Fi"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Время начала -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Время начала запрета Wi-Fi"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ЧЧ:ММ"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etStartTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="true"
                android:cursorVisible="false"
                android:inputType="none"
                android:text="22:00" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Время окончания -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Время окончания запрета Wi-Fi"
            android:textSize="14sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ЧЧ:ММ"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEndTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="true"
                android:cursorVisible="false"
                android:inputType="none"
                android:text="07:00" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Кнопки управления -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:weightSum="2">

            <Button
                android:id="@+id/btnEnableRestriction"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Запланировать ограничение"
                android:textAllCaps="false"
                android:onClick="startSchedule" />

            <Button
                android:id="@+id/btnStopRestriction"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Отменить ограничение"
                android:textAllCaps="false"
                android:onClick="cancelSchedule" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:weightSum="2">

            <Button
                android:id="@+id/btnEnableFilter"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Отключить WEB"
                android:textAllCaps="false"
                android:onClick="enableFilter" />

            <Button
                android:id="@+id/btnDisableFilter"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Включить WEB"
                android:textAllCaps="false"
                android:onClick="disableFilter" />
        </LinearLayout>

        <!-- Блок индикаторов с цветовой индикацией -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="14dp"
            android:elevation="3dp"
            android:layout_marginBottom="20dp">

            <!-- 1. Ограничение запланировано -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/dotScheduled"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/circle_gray"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ограничение запланировано на:"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvScheduledTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="—"
                    android:textSize="15sp"
                    android:gravity="end"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- 2. Ограничение активно до -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <View
                    android:id="@+id/dotActiveUntil"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/circle_gray"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ограничение активно до:"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvActiveUntil"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="—"
                    android:textSize="15sp"
                    android:gravity="end"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- 3. Ограничение отменено -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <View
                    android:id="@+id/dotWebEnabled"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/circle_green"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WEB доступен"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvWebEnabled"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="—"
                    android:textSize="15sp"
                    android:gravity="end"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btn_checkState"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="Проверить состояние WEB"
            android:textAllCaps="false"
            android:onClick="checkWan"/>

        <Button
            android:id="@+id/btn_view_log"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="Показать LOG"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="Настройки"
            android:textAllCaps="false" />

    </LinearLayout>
</LinearLayout>